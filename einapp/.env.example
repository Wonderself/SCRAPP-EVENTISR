# Auth (REQUIRED - no default, must be set)
APP_PASSWORD=your_password_here

# WhatsApp Business Cloud API
WHATSAPP_PHONE_NUMBER_ID=xxxxx
WHATSAPP_ACCESS_TOKEN=xxxxx
WHATSAPP_VERIFY_TOKEN=your_verify_token_here
WHATSAPP_APP_SECRET=your_app_secret_here
EINAT_PHONE_NUMBER=972XXXXXXXXX

# OpenAI (Whisper only)
OPENAI_API_KEY=xxxxx

# OpenWeatherMap (free tier)
OPENWEATHER_API_KEY=xxxxx

# Anthropic — Claude API
ANTHROPIC_API_KEY=xxxxx
CHAT_MODEL=claude-sonnet-4-20250514
UTILITY_MODEL=claude-haiku-4-5-20251001

# App
APP_URL=https://einapp.example.com
TIMEZONE=Asia/Jerusalem
CRON_SECRET=your_cron_secret_here
MORNING_MESSAGE_HOUR=7
MORNING_MESSAGE_MINUTE=0
EVENING_MESSAGE_HOUR=16
EVENING_MESSAGE_MINUTE=30

# Memory
MEMORY_DIR=./data/memory
MEMORY_MAX_FILE_SIZE_KB=50
