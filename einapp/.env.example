# Auth (REQUIRED - no default, must be set)
APP_PASSWORD=your_password_here

# WhatsApp Business Cloud API
WHATSAPP_PHONE_NUMBER_ID=xxxxx
WHATSAPP_ACCESS_TOKEN=xxxxx
WHATSAPP_VERIFY_TOKEN=your_verify_token_here
WHATSAPP_APP_SECRET=your_app_secret_here
EINAT_PHONE_NUMBER=972XXXXXXXXX

# Developer phone (optional — receives copies of all WhatsApp messages)
DEV_PHONE_NUMBER=972XXXXXXXXX

# Google Cloud (TTS + STT — free tier: 4M chars TTS + 60 min STT / month)
# Enable: Cloud Text-to-Speech API + Cloud Speech-to-Text API
GOOGLE_CLOUD_API_KEY=xxxxx

# Gemini AI (primary — free via AI Studio)
# Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=xxxxx

# Groq AI (fallback — free: 14400 req/day)
# Get key: https://console.groq.com/keys
GROQ_API_KEY=xxxxx

# WhatsApp voice replies (set to false to disable voice note replies)
WHATSAPP_VOICE_REPLY=true

# Cron secret (REQUIRED for /api/cron and /api/whatsapp/test)
CRON_SECRET=your_cron_secret_here

# Memory
MEMORY_DIR=./data/memory
MEMORY_MAX_FILE_SIZE_KB=50
